<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/bg_grid">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="14dp">
        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#EAF1EC"/>
    </LinearLayout>
    <TextView
        android:id="@+id/tv_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/e2ee_active"
        android:textSize="12sp"
        android:textColor="#00FF66"
        android:paddingBottom="14dp"/>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingBottom="14dp">
        <TextView
            android:id="@+id/tab_chat"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/tab_chat"
            android:gravity="center"
            android:padding="9dp"
            android:textColor="#7CFFB0"
            android:textSize="13sp"
            android:background="@drawable/tab_active"/>
        <TextView
            android:id="@+id/tab_network"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/tab_network"
            android:gravity="center"
            android:padding="9dp"
            android:layout_marginStart="8dp"
            android:textColor="#8A93A0"
            android:textSize="13sp"
            android:background="@drawable/tab_inactive"/>
        <TextView
            android:id="@+id/tab_more"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/tab_more"
            android:gravity="center"
            android:padding="9dp"
            android:layout_marginStart="8dp"
            android:textColor="#8A93A0"
            android:textSize="13sp"
            android:background="@drawable/tab_inactive"/>
        <TextView
            android:id="@+id/tab_games"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/tab_games"
            android:gravity="center"
            android:padding="9dp"
            android:layout_marginStart="8dp"
            android:textColor="#8A93A0"
            android:textSize="13sp"
            android:background="@drawable/tab_inactive"/>
    </LinearLayout>

    <ScrollView
        android:id="@+id/scroll_messages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/glass_card"
        android:padding="12dp">
        <LinearLayout
            android:id="@+id/container_messages"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>
    </ScrollView>

    <LinearLayout
        android:id="@+id/container_network"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@drawable/glass_card"
        android:padding="18dp"
        android:visibility="gone">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/diagnostics_title"
            android:textColor="#7CFFB0"
            android:textSize="12sp"
            android:textStyle="bold"
            android:paddingBottom="16dp"/>
        <TextView
            android:id="@+id/net_transport"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/net_transport"
            android:textColor="#D5DCE4"
            android:textSize="14sp"
            android:paddingBottom="12dp"/>
        <TextView
            android:id="@+id/net_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/net_status_off"
            android:textColor="#D5DCE4"
            android:textSize="14sp"
            android:paddingBottom="12dp"/>
        <TextView
            android:id="@+id/net_e2ee"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/net_status_off"
            android:textColor="#D5DCE4"
            android:textSize="14sp"
            android:paddingBottom="12dp"/>
        <TextView
            android:id="@+id/net_cipher"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/net_cipher"
            android:textColor="#D5DCE4"
            android:textSize="14sp"
            android:paddingBottom="12dp"/>
        <TextView
            android:id="@+id/net_fingerprint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/diagnostics_title"
            android:textColor="#D5DCE4"
            android:textSize="14sp"
            android:paddingBottom="12dp"/>
        <TextView
            android:id="@+id/net_server"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/net_transport"
            android:textColor="#D5DCE4"
            android:textSize="14sp"
            android:paddingBottom="12dp"/>
        <TextView
            android:id="@+id/net_reconnects"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/net_transport"
            android:textColor="#D5DCE4"
            android:textSize="14sp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/container_more"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tab_more_title"
            android:textColor="#7CFFB0"
            android:textSize="12sp"
            android:textStyle="bold"
            android:paddingBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/glass_card"
            android:padding="16dp"
            android:layout_marginBottom="12dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/my_id_title"
                android:textColor="#EAF1EC"
                android:textSize="15sp"/>
            <TextView
                android:id="@+id/tv_my_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="#7CFFB0"
                android:textSize="18sp"
                android:fontFamily="monospace"
                android:textStyle="bold"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/my_id_desc"
                android:textColor="#8A93A0"
                android:textSize="12sp"
                android:paddingBottom="10dp"/>
            <Button
                android:id="@+id/btn_copy_id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/my_id_copy"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/glass_card"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/screen_security_title"
                        android:textColor="#EAF1EC"
                        android:textSize="15sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/screen_security_desc"
                        android:textColor="#8A93A0"
                        android:textSize="12sp"
                        android:paddingTop="2dp"/>
                </LinearLayout>

                <Switch
                    android:id="@+id/switch_screen_security"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/glass_card"
            android:padding="16dp"
            android:layout_marginTop="12dp">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_lock_label"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_lock_desc"
                    android:textColor="#8A93A0"
                    android:textSize="12sp"
                    android:paddingTop="2dp"/>
            </LinearLayout>
            <Switch
                android:id="@+id/switch_app_lock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/env_section_title"
            android:textColor="#7CFFB0"
            android:textSize="12sp"
            android:textStyle="bold"
            android:paddingTop="20dp"
            android:paddingBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/glass_card"
            android:padding="16dp">
            <TextView
                android:id="@+id/tv_env_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/env_checking"
                android:textColor="#EAF1EC"
                android:textSize="14sp"/>
            <TextView
                android:id="@+id/tv_env_note"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/env_note"
                android:textColor="#8A93A0"
                android:textSize="12sp"
                android:paddingTop="8dp"
                android:visibility="gone"/>
            <TextView
                android:id="@+id/tv_integrity_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/integrity_ok"
                android:textColor="#EAF1EC"
                android:textSize="14sp"
                android:paddingTop="12dp"/>
        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:id="@+id/container_games"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/games_title"
                android:textColor="#7CFFB0"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingBottom="12dp"/>
            <LinearLayout
                android:id="@+id/card_chess"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/glass_card"
                android:padding="16dp"
                android:layout_marginBottom="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="&#9823;" android:textSize="28sp" android:layout_marginEnd="16dp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/game_chess" android:textColor="#FFFFFF" android:textSize="16sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/game_soon" android:textColor="#8A93A0" android:textSize="12sp" android:paddingTop="2dp"/>
                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:id="@+id/card_backgammon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/glass_card"
                android:padding="16dp"
                android:layout_marginBottom="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="&#127922;" android:textSize="28sp" android:layout_marginEnd="16dp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/game_backgammon" android:textColor="#FFFFFF" android:textSize="16sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/game_soon" android:textColor="#8A93A0" android:textSize="12sp" android:paddingTop="2dp"/>
                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:id="@+id/card_go"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/glass_card"
                android:padding="16dp"
                android:layout_marginBottom="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="&#9899;" android:textSize="28sp" android:layout_marginEnd="16dp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/game_go" android:textColor="#FFFFFF" android:textSize="16sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/game_soon" android:textColor="#8A93A0" android:textSize="12sp" android:paddingTop="2dp"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/container_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="14dp">
        <EditText
            android:id="@+id/et_message"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:hint="@string/msg_hint"
            android:textColorHint="#6B7480"
            android:textColor="#EAF1EC"
            android:background="@drawable/glass_input"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:gravity="center_vertical"
            android:maxLines="1"
            android:textSize="16sp"/>
        <Button
            android:id="@+id/btn_send"
            android:padding="0dp"
            android:gravity="center"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:text="▶"
            android:textSize="18sp"
            android:layout_marginStart="9dp"
            android:background="@drawable/btn_send_bg"
            android:textColor="#06210F"/>
    </LinearLayout>
</LinearLayout>
